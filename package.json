{
  "name": "neurobreath-platform",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "yarn --cwd web dev",
    "dev:clean": "yarn --cwd web dev:clean",
    "build": "yarn --cwd web build",
    "start": "yarn --cwd web start",
    "lint": "yarn --cwd web lint",
    "typecheck": "yarn --cwd web typecheck",
    "verify": "yarn lint && yarn typecheck && yarn build",
    "clean": "node scripts/clean.mjs",
    "reinstall": "node scripts/clean.mjs --deep && yarn --cwd web install",
    "doctor": "node scripts/doctor.mjs",
    "trust:check": "yarn --cwd web tsx ../scripts/trust-check.ts",
    "brand:icons": "./.venv/bin/python web/scripts/generate-brand-icons.py",
    "brand:icons:source": "./.venv/bin/python web/scripts/generate-brand-icons.py --source web/public/brand-source.png",
    "brand:icons:poster": "./.venv/bin/python web/scripts/generate-brand-icons.py --source web/public/brand-source.png --auto-crop-mark",
    "test:e2e": "yarn --cwd web test:e2e",
    "test:visual": "yarn --cwd web test:visual",
    "test:visual:update": "yarn --cwd web test:visual:update"
  }
}
