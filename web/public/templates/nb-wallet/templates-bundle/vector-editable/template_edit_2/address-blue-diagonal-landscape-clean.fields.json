  "slots": {
    "profilePhoto": {
      "id": "slot_profilePhoto",
      "box": [
        1180,
        110,
        300,
        300
      ],
      "type": "image",
      "fit": "cover",
      "preserveAspectRatio": "xMidYMid slice"
    },
    "qr": {
      "id": "slot_qr",
      "box": [
        1180,
        430,
        300,
        300
      ],
      "type": "qr",
      "fit": "contain",
      "preserveAspectRatio": "xMidYMid meet",
      "qr": {
        "payload": "shareUrl",
        "errorCorrection": "M",
        "margin": 2
      }
    },
    "barcode": {
      "id": "slot_barcode",
      "box": [
        140,
        690,
        820,
        90
      ],
      "type": "barcode",
      "fit": "contain",
      "preserveAspectRatio": "xMidYMid meet",
      "barcode": {
        "format": "code128",
        "payload": "shareText",
        "quietZone": 10
      }
    },
    "logo": {
      "id": "slot_logo",
      "box": [
        140,
        80,
        220,
        90
      ],
      "type": "image",
      "fit": "contain",
      "preserveAspectRatio": "xMidYMid meet"
    }
  },
  "colors": {
    "cssVars": [
      "--nb-bg",
      "--nb-panel",
      "--nb-text",
      "--nb-muted",
      "--nb-accent",
      "--nb-accent2",
      "--nb-gold"
    ]
  },
  "recommendedExport": [
    {
      "format": "png",
      "scale": 2
    },
    {
      "format": "pdf"
    }
  ],
  "share": {
    "qrPayloadOptions": [
      "shareUrl",
      "vCard",
      "mailto",
      "tel",
      "website"
    ],
    "default": "shareUrl"
  }
}