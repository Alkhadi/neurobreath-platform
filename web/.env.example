## Database
##
## Local/dev + most hosts:
DATABASE_URL=
## Prisma Postgres:
PRISMA_DATABASE_URL=
##
## Vercel Postgres (supported automatically by the app if DATABASE_URL is blank):
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=

# Public site URL (used for canonical URLs / SEO fallbacks)
NEXT_PUBLIC_SITE_URL=

# Optional authentication (NextAuth JWT + Credentials) — used for /uk login flows
# If you use any custom basePath, ensure NEXTAUTH_URL includes it.
NEXTAUTH_URL=
NEXTAUTH_SECRET=
NEXTAUTH_DEBUG=
AUTH_URL=
AUTH_SECRET=
NB_AUTH_ENCRYPTION_KEY=
PASSWORD_PEPPER=
TWOFA_ENCRYPTION_KEY=

# SMTP for magic link sign-in (Email provider)
# Both naming styles supported for compatibility
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=

# Optional OAuth providers (Auth.js / NextAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# NB-Card admin allowlist (comma-separated emails)
ADMIN_EMAILS=

# Password reset emails (and auth email sender)
EMAIL_FROM=
# Must include the /uk prefix if your reset pages live there (e.g. https://neurobreath.co.uk/uk)
SITE_BASE_URL=

# Abacus.AI (PageBuddy / AI Coach)
ABACUSAI_API_KEY=

# Optional: Buddy observability sampling (0..1)
BUDDY_OBS_SAMPLE_RATE=

# Resend (outbound email sender)
# See web/RESEND_SETUP_GUIDE.md for detailed setup instructions
RESEND_API_KEY=
# Recommended: info@neurobreath.co.uk (then forward to your inbox via Cloudflare Email Routing)
CONTACT_TO=
CONTACT_FROM=
# Set to "true" to skip actual email sending in development (logs to console instead)
SKIP_EMAIL_SEND=

# Cloudflare Turnstile (Contact form spam protection)
# For local development, use Cloudflare Turnstile test keys (kept in .env.local)
# For production, get your keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: SEND report generation (if enabled)
OPENAI_API_KEY=
ABACUS_API_KEY=

# Optional: Buddy authoritative sources
# NHS Website Content API v2 (requires API key). If unset, Buddy falls back to other sources.
NHS_WEBSITE_CONTENT_API_KEY=
# Environment: sandbox | integration | production (selects base URL automatically)
# LOCAL DEV:  use "sandbox" (no key required, limited content)
# VERCEL PRODUCTION: MUST be "production" — set in Vercel dashboard under Production env vars
# VERCEL PREVIEW:    use "integration" with an integration-tier API key
# Failing to set this to "production" on Vercel means all NHS calls go to the sandbox,
# which has limited content and causes NHS retrieval to return empty results.
NHS_WEBSITE_CONTENT_API_ENV=sandbox
# Optional override (defaults based on NHS_WEBSITE_CONTENT_API_ENV)
# Prefer this name going forward:
NHS_WEBSITE_CONTENT_API_BASE=
# Back-compat alias (still supported by the app):
NHS_WEBSITE_CONTENT_BASE_URL=

# Optional: NCBI E-utilities identifiers (recommended by NCBI usage guidance)
NCBI_EMAIL=
NCBI_TOOL=
# Optional API key to increase NCBI rate limits
NCBI_API_KEY=

# Optional: S3 uploads (AWS SDK default credentials chain)
AWS_BUCKET_NAME=

# Firebase (client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
AWS_FOLDER_PREFIX=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe (for donation/support page)
# Public key is safe to expose; used client-side for Stripe Buy Buttons
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe secret key (server-side only — never expose to client)
STRIPE_SECRET_KEY=

# Stripe webhook endpoint secret (for /api/webhook/stripe signature verification)
STRIPE_WEBHOOK_SECRET=

# Firebase Admin SDK service account (server-side only — needed for webhook entitlement writes)
# Option 1: full JSON string of the Firebase service account key
FIREBASE_SERVICE_ACCOUNT_KEY=
# Option 2: individual env vars (used as fallback when JSON key is not set)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Site content indexer — base URL for crawling public pages into Firestore
# Default: https://neurobreath.co.uk (only needed if you want to override)
SITE_INDEX_BASE_URL=

# Buddy public base URL (for link generation in chat responses)
BUDDY_PUBLIC_BASE_URL=

# OpenAI model overrides (optional — defaults are gpt-4o-mini / text-embedding-3-small)
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=

# Internal secret for admin/maintenance endpoints (finalize-preview, maintain-preview)
# Generate with: openssl rand -hex 32
# Required to call POST /api/nb-card/share/finalize-preview (server-side preview generation / retry)
# and POST /api/nb-card/share/maintain-preview (preview lifecycle maintenance job)
NB_INTERNAL_SECRET=
